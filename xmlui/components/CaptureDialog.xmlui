<Component
  name="CaptureDialog"
  method.open="() => { isExtracting = false; errorMessage = ''; activePanel = 'capture'; }"
  method.close="() => { if (activePanel === 'capture') activePanel = ''; }"
  method.toggle="() => { if (activePanel === 'capture') { activePanel = ''; } else { isExtracting = false; errorMessage = ''; activePanel = 'capture'; } }"
  var.isExtracting="{false}"
  var.errorMessage=""
>

  <Card
    when="{activePanel === 'capture'}"
    width="100%"
    marginTop="$space-3"
    marginBottom="$space-3"
    padding="$space-3"
    gap="$space-3">
    <HStack verticalAlignment="start" gap="$space-2">
      <H3 width="*">Capture Event from Poster</H3>
      <Icon
        name="close"
        tooltip="Hide poster capture"
        width="20px"
        height="20px"
        color="$color-text-secondary"
        onClick="activePanel = ''" />
    </HStack>
    <VStack gap="$space-3" padding="$space-2">

      <!-- Select image -->
      <VStack when="{!isExtracting}" gap="$space-2">
        <Text>Take a photo of an event poster, or select one from your library.</Text>
        <Button label="Choose Image" icon="l-file-up" onClick="imageInput.open()" />
        <FileInput
          id="imageInput"
          acceptsFileType="{['image/*']}"
          displayWhen="{false}"
          onDidChange="(files) => {
            if (!files || files.length === 0) return;
            isExtracting = true;
            errorMessage = '';
            const result = window.resizeAndUpload(files[0], appGlobals.supabaseUrl, appGlobals.supabasePublishableKey);
            isExtracting = false;
            if (result && result.event) {
              pickEvent = {
                title: result.event.title || '',
                start_time: result.event.start_time || '',
                end_time: result.event.end_time || '',
                location: result.event.location || '',
                description: result.event.description || '',
                url: result.event.url || '',
                recurrence_until: result.event.recurrence_until || ''
              };
              activePanel = '';
            } else {
              errorMessage = result?.error || 'Failed to extract event';
            }
          }"
        />
      </VStack>

      <!-- Extracting spinner -->
      <VStack when="{isExtracting}" horizontalAlignment="center" gap="$space-2" padding="$space-4">
        <Spinner />
        <Text>Extracting event details...</Text>
      </VStack>

      <!-- Error message -->
      <Text
        when="{errorMessage}"
        value="{errorMessage}"
        color="$color-danger-500"
      />

    </VStack>
  </Card>
</Component>
